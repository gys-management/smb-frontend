{
  "name": "smb-app",
  "version": "1.0.1",
  "description": "Stock Management Billing",
  "author": "sgeek017@gmail.com",
  "homepage": "https://smb.gysite.in/",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "eslint": "eslint . --ext .ts",
    "start:ionic": "ionic serve --host 0.0.0.0 --port 8500 --aot",
    "start:ionic:pwa": "npm run deploy_web:local && firebase serve --host 0.0.0.0 --port=8200",
    "deploy_web:local": "ionic build --configuration=local --aot=true --output-hashing=all --release",
    "deploy_web:dev": "ionic build --configuration=dev --aot=true --output-hashing=all --release",
    "firebase:dev:useproject": "firebase use --add ionic-angular-61cb7",
    "firebase:dev": "npm run firebase:dev:useproject && firebase deploy --only hosting:smb-app-dev",
    "run:deploy:dev": "npm run deploy_web:dev && npm run firebase:dev",
    "deploy_web:prod": "ionic build --prod --aot=true --output-hashing=all --release",
    "firebase:prod:useproject": "firebase use --add stockmanagementbilling-adb46",
    "firebase:prod": "npm run firebase:prod:useproject && firebase deploy --only hosting:smb-app",
    "run:deploy:prod": "npm run deploy_web:prod && npm run firebase:prod",
    "deploy_android:local": "ionic capacitor run android --prod --configuration=local --aot=true --release --output-hashing=all",
    "deploy_android:local:live": "ionic capacitor run android --aot=true --release --output-hashing=all -l",
    "deploy_android:dev": "ionic capacitor run android --prod --configuration=dev --aot=true --release --output-hashing=all",
    "deploy_android:prod": "ionic capacitor run android --prod --aot=true --release --output-hashing=all",
    "deploy_ios:local": "ionic capacitor run ios --aot=true --release --output-hashing=all",
    "deploy_ios:dev": "ionic capacitor run ios --prod --configuration=dev --aot=true --release --output-hashing=all",
    "deploy_ios:prod": "ionic capacitor run ios --prod --aot=true --release --output-hashing=all",
    "generate_electron:mac": "electron-packager ./electron smbapp --overwrite --platform=darwin --arch=x64 --prune=true --out=release-builds",
    "generate_electron:win": "electron-packager ./electron smbapp --overwrite --asar=true --platform=win32 --arch=ia32 --prune=true --out=release-builds --version-string.CompanyName=CE --version-string.FileDescription=CE --version-string.ProductName='smb Electron App'",
    "run_MongoScript_backup": "cd /Users/madhankumar/Projects/training/GYS/Stockmangement/Code/smb-db-scripts && npm run start"
  },
  "private": true,
  "husky": {
    "hooks": {
      "pre-commit": "npm run eslint"
    }
  },
  "dependencies": {
    "@angular/animations": "~11.2.0",
    "@angular/cdk": "^11.2.11",
    "@angular/common": "~11.2.0",
    "@angular/core": "~11.2.0",
    "@angular/fire": "^6.1.4",
    "@angular/forms": "~11.2.0",
    "@angular/material": "^11.2.11",
    "@angular/platform-browser": "~11.2.0",
    "@angular/platform-browser-dynamic": "~11.2.0",
    "@angular/router": "~11.2.0",
    "@angular/service-worker": "~11.2.0",
    "@capacitor/android": "^2.4.7",
    "@capacitor/core": "2.4.7",
    "@ionic-native/core": "^5.32.1",
    "@ionic-native/google-plus": "^5.32.1",
    "@ionic/angular": "^5.5.2",
    "@ionic/storage": "^3.0.4",
    "@ionic/storage-angular": "^3.0.6",
    "firebase": "^8.4.3",
    "husky": "^6.0.0",
    "rxjs": "~6.6.0",
    "tslib": "^2.0.0",
    "zone.js": "~0.10.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "~0.1102.4",
    "@angular-eslint/builder": "4.2.0",
    "@angular-eslint/eslint-plugin": "4.2.0",
    "@angular-eslint/eslint-plugin-template": "4.2.0",
    "@angular-eslint/schematics": "4.2.0",
    "@angular-eslint/template-parser": "4.2.0",
    "@angular/cli": "~11.2.4",
    "@angular/compiler": "~11.2.0",
    "@angular/compiler-cli": "~11.2.0",
    "@angular/language-service": "~11.2.0",
    "@capacitor/cli": "2.4.7",
    "@ionic/angular-toolkit": "^3.1.1",
    "@types/jasmine": "~3.6.0",
    "@types/jasminewd2": "~2.0.3",
    "@types/node": "^12.11.1",
    "@typescript-eslint/eslint-plugin": "4.16.1",
    "@typescript-eslint/parser": "4.16.1",
    "eslint": "^7.6.0",
    "eslint-plugin-import": "2.22.1",
    "eslint-plugin-jsdoc": "30.7.6",
    "eslint-plugin-prefer-arrow": "1.2.2",
    "jasmine-core": "~3.6.0",
    "jasmine-spec-reporter": "~5.0.0",
    "karma": "~5.2.0",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-coverage-istanbul-reporter": "~3.0.2",
    "karma-jasmine": "~4.0.0",
    "karma-jasmine-html-reporter": "^1.5.0",
    "protractor": "~7.0.0",
    "ts-node": "~8.3.0",
    "typescript": "~4.0.2"
  }
}
