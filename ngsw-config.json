{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "dataGroups": [
    {
      "name": "backend-api",
      "version": 1,
      "urls": [
        "http://192.168.1.83:9090/api/**",
        "https://smb-v2-dev.herokuapp.com/api/**"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxAge": "2s",
        "maxSize": 5,
        "timeout": "2s"
      }
    },
    {
      "name": "svg",
      "version": 1,
      "urls": [
        "**/svg/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxAge": "5h",
        "maxSize": 5,
        "timeout": "3s"
      }
    }
  ],
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js",
          "/*.jpg",
          "/*.png"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(eot|svg|cur|jpg|png|webp|gif|otf|ttf|woff|woff2|ani)"
        ]
      }
    }
  ]
}